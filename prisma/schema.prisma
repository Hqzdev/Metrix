generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  employee
}

enum ResourceType {
  desk
  office
  room
  team
}

enum BookingStatus {
  active
  cancelled
  completed
  rescheduled
}

enum CalendarProvider {
  google
  microsoft
}

enum CalendarConnectionScope {
  resource
  user
}

model User {
  id             String               @id @default(cuid())
  email          String?              @unique
  name           String?
  passwordHash   String?
  role           UserRole             @default(employee)
  telegramUserId BigInt?              @unique
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  bookings       Booking[]
  sessions       Session[]
  calendars      CalendarConnection[]
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Location {
  id        String     @id
  name      String
  city      String
  address   String
  occupancy String
  members   String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  bookings  Booking[]
  resources Resource[]
}

model Resource {
  id              String               @id
  locationId      String
  name            String
  type            ResourceType
  seats           String
  occupancy       String
  priceLabel      String
  priceMinorUnits Int
  status          String
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  bookings        Booking[]
  calendarLinks   CalendarConnection[]
  location        Location             @relation(fields: [locationId], references: [id], onDelete: Cascade)
  slots           Slot[]

  @@index([locationId])
}

model Slot {
  id         String    @id
  resourceId String
  startsAt   DateTime
  endsAt     DateTime
  label      String
  createdAt  DateTime  @default(now())
  bookings   Booking[]
  resource   Resource  @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([resourceId, startsAt, endsAt])
}

model Booking {
  id                   String          @id @default(cuid())
  userId               String?
  telegramUserId        BigInt?
  locationId           String
  resourceId           String
  slotId               String?
  paidAmountMinorUnits Int
  priceLabel           String
  startsAt             DateTime
  endsAt               DateTime
  status               BookingStatus   @default(active)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  cancelledAt          DateTime?
  calendarEvents       CalendarEvent[]
  location             Location        @relation(fields: [locationId], references: [id])
  resource             Resource        @relation(fields: [resourceId], references: [id])
  slot                 Slot?           @relation(fields: [slotId], references: [id])
  user                 User?           @relation(fields: [userId], references: [id])

  @@index([resourceId, startsAt, endsAt, status])
  @@index([telegramUserId])
  @@index([userId])
}

model CalendarConnection {
  id              String                  @id @default(cuid())
  provider        CalendarProvider
  scope           CalendarConnectionScope
  userId          String?
  telegramUserId  BigInt?
  resourceId      String?
  calendarId      String                  @default("primary")
  accessTokenEnc  String?
  refreshTokenEnc String
  expiresAt       DateTime?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  events          CalendarEvent[]
  resource        Resource?               @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  user            User?                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, scope, telegramUserId, resourceId])
  @@index([resourceId])
  @@index([userId])
}

model CalendarEvent {
  id           String             @id @default(cuid())
  bookingId    String
  connectionId String
  provider     CalendarProvider
  eventId      String
  createdAt    DateTime           @default(now())
  booking      Booking            @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  connection   CalendarConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([provider, eventId])
  @@index([bookingId])
}
