{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Общий обзор состояния микросервисов Metrix: RPS, latency p95, error rate и uptime.",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Общий статус",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "metrix-prometheus" },
      "description": "Общее число HTTP-запросов в секунду по всем сервисам.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 2,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "metrix-prometheus" },
          "expr": "sum by (service) (rate(metrix_http_requests_total[$__rate_interval]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "title": "RPS по сервисам",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "metrix-prometheus" },
      "description": "P95 latency по каждому сервису в миллисекундах.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 2000 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 3,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "metrix-prometheus" },
          "expr": "histogram_quantile(0.95, sum by (service, le) (rate(metrix_http_request_duration_ms_bucket[$__rate_interval])))",
          "legendFormat": "p95 {{service}}",
          "refId": "A"
        }
      ],
      "title": "P95 Latency (мс)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "metrix-prometheus" },
      "description": "Доля 5xx ответов от общего числа запросов. Выше 1% — повод для тревоги.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "id": 4,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "metrix-prometheus" },
          "expr": "sum by (service) (rate(metrix_http_requests_total{status=~\"5..\"}[$__rate_interval])) / sum by (service) (rate(metrix_http_requests_total[$__rate_interval]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "title": "Error Rate (5xx)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "metrix-prometheus" },
      "description": "Uptime каждого сервиса в секундах с момента последнего запуска.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "id": 5,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "metrix-prometheus" },
          "expr": "metrix_process_uptime_seconds",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "title": "Process Uptime",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 6,
      "title": "booking-service",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "metrix-prometheus" },
      "description": "HTTP-запросы к booking-service по маршрутам и методам.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "id": 7,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "metrix-prometheus" },
          "expr": "sum by (method, route, status) (rate(metrix_http_requests_total{service=\"booking-service\"}[$__rate_interval]))",
          "legendFormat": "{{method}} {{route}} {{status}}",
          "refId": "A"
        }
      ],
      "title": "booking-service — запросы по маршрутам",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "metrix-prometheus" },
      "description": "Latency p50/p95/p99 для booking-service.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "id": 8,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "metrix-prometheus" },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(metrix_http_request_duration_ms_bucket{service=\"booking-service\"}[$__rate_interval])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "metrix-prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(metrix_http_request_duration_ms_bucket{service=\"booking-service\"}[$__rate_interval])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "metrix-prometheus" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(metrix_http_request_duration_ms_bucket{service=\"booking-service\"}[$__rate_interval])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "title": "booking-service — Latency percentiles",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "id": 9,
      "title": "payment-service",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "metrix-prometheus" },
      "description": "RPS и статусы ответов payment-service. 5xx здесь означают потерю денег.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 },
      "id": 10,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "metrix-prometheus" },
          "expr": "sum by (status) (rate(metrix_http_requests_total{service=\"payment-service\"}[$__rate_interval]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "title": "payment-service — RPS по статусам",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "metrix-prometheus" },
      "description": "P95 latency payment-service.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 27 },
      "id": 11,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "metrix-prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(metrix_http_request_duration_ms_bucket{service=\"payment-service\"}[$__rate_interval])))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "title": "payment-service — P95 Latency",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["metrix", "overview"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Metrix — Overview",
  "uid": "metrix-overview",
  "version": 1
}
