# booking-service env.
# Owns booking data and accepts signed calls from trusted internal services.

PORT=3001
DATABASE_URL=postgresql://metrix:password@localhost:5432/metrix
REDIS_URL=redis://localhost:6379

TRUSTED_GATEWAY_SECRET=change-me-gateway-signing-secret-32-chars
TRUSTED_GATEWAY_SECRET_NEXT=
TRUSTED_PAYMENT_SECRET=change-me-payment-signing-secret-32-chars
TRUSTED_PAYMENT_SECRET_NEXT=
TRUSTED_ANALYTICS_SECRET=change-me-analytics-signing-secret-32-chars
TRUSTED_ANALYTICS_SECRET_NEXT=
TRUSTED_ADMIN_SECRET=change-me-admin-signing-secret-32-chars
TRUSTED_ADMIN_SECRET_NEXT=

USER_ID_SIGNING_SECRET=change-me-user-id-signing-secret-32-chars
