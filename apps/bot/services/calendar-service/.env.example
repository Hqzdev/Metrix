# calendar-service env.
# Owns OAuth calendar connections and encrypted calendar tokens.

NODE_ENV=development
PORT=3002
DATABASE_URL=postgresql://metrix:password@localhost:5432/metrix
REDIS_URL=redis://localhost:6379

GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/calendar/google/callback
CALENDAR_TOKEN_SECRET=change-me-calendar-token-secret-32-chars

TRUSTED_GATEWAY_SECRET=change-me-gateway-signing-secret-32-chars
TRUSTED_GATEWAY_SECRET_NEXT=
USER_ID_SIGNING_SECRET=change-me-user-id-signing-secret-32-chars
 