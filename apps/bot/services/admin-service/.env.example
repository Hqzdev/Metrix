# admin-service env.
# Admin boundary that proxies privileged calls to booking and analytics services.

PORT=3006
DATABASE_URL=postgresql://metrix:change-me@localhost:5432/metrix
REDIS_URL=redis://localhost:6379

BOOKING_SERVICE_URL=http://localhost:3001
PAYMENT_SERVICE_URL=http://localhost:3003
ANALYTICS_SERVICE_URL=http://localhost:3005

AUDIT_RETENTION_DAYS=180
AUDIT_RETENTION_INTERVAL_MS=86400000

ADMIN_SIGNING_SECRET=change-me-admin-signing-secret-32-chars
TRUSTED_GATEWAY_SECRET=change-me-gateway-signing-secret-32-chars
TRUSTED_GATEWAY_SECRET_NEXT=
 