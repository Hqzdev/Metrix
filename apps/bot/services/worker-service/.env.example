# worker-service env.
# Runs BullMQ workers for reminders, calendar refresh and report jobs.

DATABASE_URL=postgresql://metrix:password@localhost:5432/metrix
REDIS_URL=redis://localhost:6379

CALENDAR_SERVICE_URL=http://localhost:3002
CALENDAR_SIGNING_SECRET=change-me-gateway-signing-secret-32-chars
REPORTS_DIR=/app/reports
