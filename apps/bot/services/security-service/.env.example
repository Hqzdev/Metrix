# security-service env.
# Единственный сервис, который выпускает и проверяет JWT и хранит сессии.

PORT=3008
DATABASE_URL=postgresql://metrix:change-me@localhost:5432/metrix
REDIS_URL=redis://localhost:6379

# секрет для подписи исходящих запросов security-service → другие сервисы
SECURITY_SIGNING_SECRET=change-me-security-signing-secret-32chars

# JWT ключи — используются для подписи access token
# JWT_KEY_ID — произвольный идентификатор текущего ключа (например: v1)
JWT_KEY_ID=v1
# JWT_SECRET — секрет подписи, минимум 32 символа
JWT_SECRET=change-me-jwt-secret-at-least-32-characters

# Предыдущие ключи для плавной ротации (формат: id1:secret1,id2:secret2)
# Оставь пустым если ротации ещё не было
JWT_PREVIOUS_KEYS=

# Сервисы, которым разрешено обращаться к security-service
TRUSTED_GATEWAY_SECRET=change-me-gateway-signing-secret-32-chars
TRUSTED_GATEWAY_SECRET_NEXT=
TRUSTED_ADMIN_SECRET=change-me-admin-signing-secret-32-chars
TRUSTED_ADMIN_SECRET_NEXT=
 