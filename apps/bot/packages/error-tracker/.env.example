# Конфигурация @metrix/error-tracker.
# Эти переменные читаются через readErrorTrackerConfig() в каждом сервисе.
# Копировать отдельно не нужно — они уже включены в apps/bot/.env.example.

# DSN получить: GlitchTip UI -> Settings -> Project -> Client Keys -> DSN.
# Если пустой — error-tracker работает в no-op режиме (ошибки не отправляются).
SENTRY_DSN=http://your-key@localhost:3011/1

# Среда определяет фильтрацию событий в GlitchTip/Sentry UI.
# Рекомендуемые значения: development | staging | production
SENTRY_ENVIRONMENT=development

# Доля транзакций для performance monitoring (0.0 — 1.0).
# Для production рекомендуется 0.1 (10%), чтобы не исчерпать квоту.
SENTRY_TRACES_SAMPLE_RATE=0.1
