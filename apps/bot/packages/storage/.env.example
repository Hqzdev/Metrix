# Конфигурация @metrix/storage.
# Эти переменные читаются через readStorageConfig() в каждом сервисе.
# Уже включены в apps/bot/.env.example — копировать отдельно не нужно.

# Хост MinIO без протокола. В docker-compose — имя сервиса.
MINIO_ENDPOINT=minio

# Порт S3 API MinIO.
MINIO_PORT=9000

# Минимум 8 символов. Аналог AWS_ACCESS_KEY_ID.
MINIO_ACCESS_KEY=change-me-minio-access-key

# Минимум 16 символов. Аналог AWS_SECRET_ACCESS_KEY.
MINIO_SECRET_KEY=change-me-minio-secret-key-16-chars

# Использовать TLS. false для docker-compose, true для production.
MINIO_USE_SSL=false
