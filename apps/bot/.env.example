# Shared docker-compose values.
# Copy to apps/bot/.env for local compose only.
# Do not commit real .env files.

NODE_ENV=development

POSTGRES_PASSWORD=change-me-postgres-password-32-chars
REDIS_PASSWORD=change-me-redis-password-32-chars

TELEGRAM_BOT_TOKEN=123456:replace-with-botfather-token
ADMIN_TELEGRAM_IDS=123456789,987654321
TELEGRAM_MODE=polling
TELEGRAM_WEBHOOK_URL=https://bot.example.com/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=change-me-telegram-webhook-secret-32-chars

GOOGLE_CALENDAR_CLIENT_ID=replace-with-google-client-id
GOOGLE_CALENDAR_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/calendar/google/callback
CALENDAR_TOKEN_SECRET=change-me-calendar-token-secret-32-chars

# Telegram provider token from BotFather: /mybots -> <bot> -> Payments.
# Do not put YooKassa API keys like test_* or live_* here.
TELEGRAM_PAYMENT_PROVIDER_TOKEN=replace-with-botfather-payment-provider-token
PAYMENT_CURRENCY=RUB

AUDIT_RETENTION_DAYS=180
AUDIT_RETENTION_INTERVAL_MS=86400000

GATEWAY_SIGNING_SECRET=change-me-gateway-signing-secret-32-chars
PAYMENT_SIGNING_SECRET=change-me-payment-signing-secret-32-chars
ANALYTICS_SIGNING_SECRET=change-me-analytics-signing-secret-32-chars
ADMIN_SIGNING_SECRET=change-me-admin-signing-secret-32-chars
USER_ID_SIGNING_SECRET=change-me-user-id-signing-secret-32-chars
