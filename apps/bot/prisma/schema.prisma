generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["booking", "calendar", "payment", "analytics", "audit", "security"]
}

// ─── booking schema ───────────────────────────────────────────────────────────

model Location {
  id        String     @id
  name      String
  city      String
  address   String
  occupancy String
  members   String
  resources Resource[]

  @@schema("booking")
}

model Resource {
  id              String     @id
  locationId      String
  name            String
  type            String
  seats           String
  occupancy       String
  priceLabel      String
  priceMinorUnits Int
  status          String
  location        Location   @relation(fields: [locationId], references: [id])
  bookings        Booking[]
  busySlots       BusySlot[]

  @@schema("booking")
}

model Booking {
  id                     String   @id
  locationId             String
  locationName           String
  resourceId             String
  resourceName           String
  slotId                 String
  telegramUserId         BigInt
  paidAmountMinorUnits   Int
  priceLabel             String
  startsAt               String
  startsAtIso            DateTime
  endsAt                 String
  endsAtIso              DateTime
  status                 String   @default("active")
  // idempotency: уникальный ключ от клиента — защищает от дублей при retry
  idempotencyKey         String?  @unique
  calendarEventGoogle    String?
  calendarEventMicrosoft String?
  createdAt              DateTime @default(now())
  resource               Resource @relation(fields: [resourceId], references: [id])

  @@schema("booking")
}

model BusySlot {
  id         String   @id @default(cuid())
  resourceId String
  slotId     String
  resource   Resource @relation(fields: [resourceId], references: [id])

  @@unique([resourceId, slotId])
  @@schema("booking")
}

model TelegramUserPreference {
  telegramUserId BigInt   @id
  language       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@schema("booking")
}

// ─── calendar schema ──────────────────────────────────────────────────────────

model CalendarConnection {
  id             String    @id @default(cuid())
  provider       String
  scope          String
  telegramUserId BigInt
  resourceId     String?
  calendarId     String    @default("primary")
  accessToken    String?
  refreshToken   String
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([provider, scope, telegramUserId, resourceId])
  @@schema("calendar")
}

// ─── payment schema ───────────────────────────────────────────────────────────

model PendingInvoice {
  id                    String   @id
  amountMinorUnits      Int
  // pending | paid_part | completed | failed | expired
  status                String   @default("pending")
  holdId                String?
  locationId            String
  paidAmountMinorUnits  Int      @default(0)
  partNumber            Int      @default(1)
  resourceId            String
  slotId                String
  telegramUserId        BigInt
  totalAmountMinorUnits Int
  totalParts            Int      @default(1)
  completedAt           DateTime?
  supersededByInvoiceId String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@schema("payment")
}

// SlotHold — временная бронь слота до завершения оплаты.
//
// Задача: не дать двум пользователям оплатить один и тот же слот.
// Hold создаётся перед отправкой invoice и живёт ограниченное время.
// После успешного создания Booking он переводится в paid.
model SlotHold {
  id             String   @id @default(cuid())
  resourceId     String
  slotId         String
  telegramUserId BigInt
  invoiceId      String?  @unique
  // held | paid | expired | cancelled
  status         String   @default("held")
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@schema("payment")
}

// PaymentSaga — хранит состояние saga-паттерна для многочастных платежей.
//
// Проблема: оплата бронирования разбивается на N частей (лимит Telegram Stars).
// Если сервис падает между частями — нет информации о том, какие части оплачены
// и нужно ли создавать бронирование или компенсировать уже оплаченное.
//
// Решение: PaymentSaga фиксирует полное состояние flow и позволяет
// при восстановлении продолжить с последнего успешного шага.
model PaymentSaga {
  id             String   @id @default(cuid())
  invoiceId      String   @unique
  resourceId     String
  slotId         String
  telegramUserId BigInt
  chatId         BigInt
  totalAmount    Int
  paidAmount     Int      @default(0)
  // pending | awaiting_next_part | awaiting_booking | completed | failed | compensating | compensated
  status         String   @default("pending")
  currentPart    Int      @default(1)
  totalParts     Int      @default(1)
  failureReason  String?
  bookingId      String?  // заполняется когда бронирование создано
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@schema("payment")
}

// ─── analytics schema ─────────────────────────────────────────────────────────

model Report {
  id          String   @id @default(cuid())
  type        String
  status      String   @default("pending")
  filePath    String?
  error       String?
  requestedBy BigInt?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@schema("analytics")
}

// ─── audit schema ─────────────────────────────────────────────────────────────

model AuditLog {
  id            String   @id @default(cuid())
  ts            DateTime @default(now())
  service       String
  action        String
  actorUserId   BigInt?
  entityType    String?
  entityId      String?
  requestId     String?
  callerService String?
  payload       Json?

  @@index([service, action, ts])
  @@index([entityType, entityId])
  @@schema("audit")
}

// ─── security schema ──────────────────────────────────────────────────────────

// SecuritySession хранит активные пользовательские сессии.
//
// Каждая запись = один refresh token.
// После использования токен удаляется и создаётся новый (atomic rotation).
// expiresAt не продлевается при ротации — сессия живёт ровно 30 дней.
model SecuritySession {
  id           String   @id @default(cuid())
  userId       String
  userRole     String
  // одноразовый токен, хранится в открытом виде — доступ к БД = доступ к сессиям
  // доп. защита: только security-service имеет права на security schema
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  // быстрый поиск всех сессий пользователя (logout all, смена пароля)
  @@index([userId])
  @@schema("security")
}
