---
title: Bot Runtime Database Schema
---
erDiagram
    booking_Location {
        string id PK
        string name
        string city
        string address
        string occupancy
        string members
    }

    booking_Resource {
        string id PK
        string locationId FK
        string name
        string type
        string seats
        string occupancy
        string priceLabel
        int priceMinorUnits
        string status
    }

    booking_Booking {
        string id PK
        string locationId
        string locationName
        string resourceId FK
        string resourceName
        string slotId
        bigint telegramUserId
        int paidAmountMinorUnits
        string priceLabel
        datetime startsAtIso
        datetime endsAtIso
        string status
        string idempotencyKey UK
        string calendarEventGoogle
        string calendarEventMicrosoft
        datetime createdAt
    }

    booking_BusySlot {
        string id PK
        string resourceId FK
        string slotId UK
    }

    calendar_CalendarConnection {
        string id PK
        string provider
        string scope
        bigint telegramUserId
        string resourceId
        string calendarId
        string accessToken
        string refreshTokenEncrypted
        datetime expiresAt
        datetime createdAt
        datetime updatedAt
    }

    payment_PendingInvoice {
        string id PK
        int amountMinorUnits
        string status
        string holdId
        string locationId
        int paidAmountMinorUnits
        int partNumber
        string resourceId
        string slotId
        bigint telegramUserId
        int totalAmountMinorUnits
        int totalParts
        datetime completedAt
        string supersededByInvoiceId
        datetime createdAt
        datetime updatedAt
    }

    payment_SlotHold {
        string id PK
        string resourceId
        string slotId
        bigint telegramUserId
        string invoiceId UK
        string status
        datetime expiresAt
        datetime createdAt
        datetime updatedAt
    }

    payment_PaymentSaga {
        string id PK
        string invoiceId UK
        string resourceId
        string slotId
        bigint telegramUserId
        bigint chatId
        int totalAmount
        int paidAmount
        string status
        int currentPart
        int totalParts
        string failureReason
        string bookingId
        datetime createdAt
        datetime updatedAt
    }

    analytics_Report {
        string id PK
        string type
        string status
        string filePath
        string error
        bigint requestedBy
        datetime createdAt
        datetime updatedAt
    }

    audit_AuditLog {
        string id PK
        datetime ts
        string service
        string action
        bigint actorUserId
        string entityType
        string entityId
        string requestId
        string callerService
        json payload
    }

    booking_Location ||--o{ booking_Resource : has
    booking_Resource ||--o{ booking_Booking : booked
    booking_Resource ||--o{ booking_BusySlot : blocks
    payment_SlotHold ||--o| payment_PendingInvoice : protects
    payment_PendingInvoice ||--|| payment_PaymentSaga : tracked_by
    booking_Booking ||--o{ audit_AuditLog : audited_as_entity
    payment_PaymentSaga ||--o{ audit_AuditLog : audited_as_entity
