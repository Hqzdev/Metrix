---
title: Redis State, Streams, Retry And DLQ
---
flowchart LR
    subgraph state["Short-lived Redis state"]
        RL["rate:user:{id}"]
        RP["replay:{requestId}"]
        UPD["telegram:update:{id}"]
        FSM["session:{telegramUserId}"]
        LOCK["lock:slot:{resourceId}:{slotId}"]
    end

    subgraph producers["Publishers"]
        GW[bot-gateway]
        BK[booking-service]
        PAY[payment-service]
        CAL[calendar-service]
        ANA[analytics-service]
        ADM[admin-service]
    end

    subgraph streams["Redis Streams"]
        S1["stream:booking.created"]
        S2["stream:booking.cancelled"]
        S3["stream:payment.completed"]
        S4["stream:notification.send"]
        S5["stream:report.ready"]
    end

    subgraph consumers["Consumers"]
        C1[analytics-service]
        C2[payment-service]
        C3[notification-service]
        C4[worker-service]
    end

    subgraph retry["Failure handling"]
        PENDING[Pending messages]
        RETRY[Retry by consumer group]
        DLQ["dlq:{stream}"]
        REPLAY[admin-service DLQ replay]
        AUD[audit log dlq.replayed]
    end

    GW --> RL
    GW --> UPD
    GW --> FSM
    BK --> LOCK
    BK --> RP
    PAY --> RP
    CAL --> RP
    ADM --> RP

    BK --> S1
    BK --> S2
    PAY --> S3
    PAY --> S4
    ANA --> S5

    S1 --> C1
    S2 --> C1
    S3 --> C2
    S4 --> C3
    S5 --> C3

    C1 -->|handler fails| PENDING
    C2 -->|handler fails| PENDING
    C3 -->|handler fails| PENDING
    PENDING --> RETRY
    RETRY -->|too many deliveries| DLQ
    DLQ --> REPLAY
    REPLAY --> S1
    REPLAY --> S2
    REPLAY --> S3
    REPLAY --> S4
    REPLAY --> S5
    REPLAY --> AUD
