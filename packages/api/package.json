{
  "name": "@metrix/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prisma:generate": "npm --prefix ../.. run prisma:generate",
    "prisma:migrate": "npm --prefix ../.. run prisma:migrate",
    "prisma:seed": "npm --prefix ../.. run prisma:seed",
    "prisma:validate": "npm --prefix ../.. run prisma:validate",
    "test": "npm --prefix ../.. run test:unit",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "bullmq": "^5.0.0",
    "ioredis": "^5.0.0",
    "ws": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.0.0",
    "prisma": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.0.0"
  }
}
