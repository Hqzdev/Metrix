{
  "name": "metrix",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:api && npm run build:bot && npm run build:web",
    "build:api": "npm --prefix packages/api run build",
    "build:bot": "npm --prefix apps/bot run build",
    "build:web": "npm --prefix apps/web run build",
    "dev:api": "npm --prefix packages/api run build -- --watch",
    "dev:bot": "npm --prefix apps/bot run dev",
    "dev:web": "npm --prefix apps/web run dev",
    "prepare": "husky",
    "lint": "npm --prefix apps/web run lint",
    "docs:typedoc": "typedoc --options typedoc.json",
    "hook:pre-commit": "npm run typecheck:api && npm run typecheck:web",
    "hook:pre-push": "npm run audit:security && npm test && npm run openapi:validate",
    "audit:security": "npm audit --audit-level=high",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:validate": "env DATABASE_URL=${DATABASE_URL:-postgresql://user:pass@localhost:5432/metrix} prisma validate --schema prisma/schema.prisma",
    "prisma:seed": "tsx prisma/seed.ts",
    "db:backup": "sh scripts/backup-postgres.sh",
    "openapi:validate": "node scripts/validate-openapi.mjs docs/openapi/metrix-bot-api.yaml",
    "test": "node --import tsx --test \"tests/**/*.test.ts\"",
    "test:e2e": "node --import tsx --test \"tests/e2e/**/*.test.ts\"",
    "test:integration": "node --import tsx --test \"tests/integration/**/*.test.ts\"",
    "test:unit": "node --import tsx --test \"tests/unit/**/*.test.ts\"",
    "test:contracts": "node --import tsx --test \"tests/contracts/**/*.contract.test.ts\"",
    "typecheck": "npm run typecheck:api && npm run typecheck:bot && npm run typecheck:web",
    "typecheck:api": "npm --prefix packages/api run typecheck",
    "typecheck:bot": "npm --prefix apps/bot run typecheck",
    "typecheck:web": "npm --prefix apps/web run typecheck",
    "verify": "npm run prisma:validate && npm run typecheck:api && npm test"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.0"
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@types/node": "^22.0.0",
    "husky": "^9.1.7",
    "prisma": "^6.0.0",
    "tsx": "^4.20.6",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^5.0.0"
  }
}
